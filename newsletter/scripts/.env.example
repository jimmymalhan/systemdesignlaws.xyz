# Substack Session (cookie-based, no password)
# Paste your session cookies here. They persist across laptop restarts.
#
# How to get cookies:
# 1. Log in to https://substack.com (Google SSO or magic link)
# 2. DevTools → Application → Cookies → https://substack.com
# 3. Copy values for: substack.sid and connect.sid
#
# Format (choose one):

# Option A: Paste the full cookie string from DevTools
# SUBSTACK_COOKIES="substack.sid=s%3Axxx...; connect.sid=s%3Ayyy..."

# Option B: Paste each value separately
SUBSTACK_SID=
CONNECT_SID=

# Publication (your Substack subdomain)
SUBSTACK_PUBLICATION=https://systemdesignlaws.substack.com
